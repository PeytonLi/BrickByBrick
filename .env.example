# --- Gemini (one key powers Antigravity orchestrator + Gemini 3.5 Pro strong
#     solver + Gemma 4 weak solver + Flash computer-use + Gemini Live narration) ---
GEMINI_API_KEY=
ANTIGRAVITY_AGENT=antigravity-preview-05-2026
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_LIVE_SAMPLE_RATE=24000
STRONG_MODEL=gemini-3.1-pro-preview
WEAK_MODEL=gemma-4-26b-a4b-it
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- DigitalOcean Serverless Inference (automatic fallback on Gemini 429/5xx) ---
DIGITALOCEAN_MODEL_ACCESS_KEY=
DO_STRONG_MODEL=anthropic-claude-4.6-sonnet
DO_WEAK_MODEL=llama3.3-70b-instruct
DO_EMBED_MODEL=gte-large

# --- DigitalOcean GPU Training (alternative to Prime Intellect) ---
# BBB_TRAINING_PROVIDER: 'prime' (default) or 'do-gpu'
BBB_TRAINING_PROVIDER=prime
DO_API_TOKEN=
DO_SSH_KEY_ID=
DO_GPU_REGION=nyc3
DO_GPU_TYPE=H100_80GB

# --- LiveKit (audio room + AgentAudioVisualizer) ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Prime Intellect (LoRA training on GPU spot nodes, via the `prime` CLI) ---
PRIME_API_KEY=
PRIME_GPU_ID=
PRIME_SSH_KEY_PATH=
NEXT_PUBLIC_TRAINING_BUCKET_URI=

# --- Hugging Face (exact Gemma model download on the Prime H100 pod) ---
HF_TOKEN=
BBB_GEMMA_MODEL=google/gemma-4-26B-A4B-it
BBB_TRAINING_MAX_STEPS=20

# --- MongoDB Atlas (loop run / pair / event persistence via @brickbybrick/db) ---
MONGODB_ATLAS_URI=
MONGODB_DB_NAME=brickbybrick

# --- Demo mode (deterministic stub loops for e2e/CI; 0 = live) ---
BBB_DEMO_MODE=0
